{
	"schemaVersion": 1,
	"id": "voxy-extra",
	"version": "${version}",
	"name": "Voxy Extra",
	"description": "Adds features that shouldn't be in Voxy.",
	"authors": [
		"ImGRUI"
	],
    "contributors": [
        "Werkhil"
    ],
	"contact": {
		"issues": "https://github.com/ImGRUI/voxy-extra/issues",
		"sources": "https://github.com/ImGRUI/voxy-extra",
        "homepage": "https://modrinth.com/mod/voxy-extra"
	},
	"license": "LGPLv3",
	"icon": "assets/voxy-extra/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"me.imgrui.VoxyExtra"
		],
        "sodium:config_api_user": [
          "me.imgrui.config.sodium.VoxyExtraConfigBuilder"
        ],
        "modmenu": [
          "me.imgrui.config.ModMenuIntegration"
        ]
	},
	"mixins": [
		"voxy-extra.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"fabric-api": "*",
        "voxy": ">=0.2.14-alpha"
	}
}
